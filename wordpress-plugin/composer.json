{
    "name": "studyflow/orca-dam-picker",
    "description": "WordPress media picker backed by ORCA DAM.",
    "type": "wordpress-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "yahnis-elsts/plugin-update-checker": "^5.5",
        "woocommerce/action-scheduler": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6.1",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "OrcaDam\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OrcaDam\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
